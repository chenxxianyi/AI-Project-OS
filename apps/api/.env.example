# Server
SERVER_PORT=8080

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=aiproject_dev
DB_NAME=ai_project_os

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT
JWT_SECRET=change-me-in-production
JWT_EXPIRATION_HOURS=72

# ── AI Provider Configuration ────────────────────────────────────────────────
# AI_PROVIDER: mock | openai | deepseek | groq | moonshot | siliconflow |
#              zhipu | together | ollama | mistral | perplexity | custom
#
# Built-in presets (no AI_BASE_URL needed):
#   openai       → https://api.openai.com/v1
#   deepseek     → https://api.deepseek.com/v1
#   groq         → https://api.groq.com/openai/v1
#   moonshot     → https://api.moonshot.cn/v1        (Kimi)
#   siliconflow  → https://api.siliconflow.cn/v1
#   zhipu        → https://open.bigmodel.cn/api/paas/v4
#   together     → https://api.together.xyz/v1
#   ollama       → http://localhost:11434/v1          (no API key needed)
#   mistral      → https://api.mistral.ai/v1
#   perplexity   → https://api.perplexity.ai
#   custom       → set AI_BASE_URL to any OpenAI-compatible endpoint
#
# Default (no real AI call):
AI_PROVIDER=mock
AI_MODEL=mock-v1
AI_API_KEY=
AI_BASE_URL=
#
# ── Examples ──────────────────────────────────────────────────────────────────
# DeepSeek (recommended, cost-effective):
#   AI_PROVIDER=deepseek
#   AI_MODEL=deepseek-chat
#   AI_API_KEY=sk-xxxxxxxxxxxxxxxx
#
# OpenAI:
#   AI_PROVIDER=openai
#   AI_MODEL=gpt-4o
#   AI_API_KEY=sk-xxxxxxxxxxxxxxxx
#
# Groq (fast inference, free tier):
#   AI_PROVIDER=groq
#   AI_MODEL=llama-3.3-70b-versatile
#   AI_API_KEY=gsk_xxxxxxxxxxxxxxxx
#
# Moonshot / Kimi:
#   AI_PROVIDER=moonshot
#   AI_MODEL=moonshot-v1-8k
#   AI_API_KEY=sk-xxxxxxxxxxxxxxxx
#
# Ollama (local, no API key):
#   AI_PROVIDER=ollama
#   AI_MODEL=qwen2.5:14b
#   AI_API_KEY=
#
# Custom endpoint (any OpenAI-compatible API):
#   AI_PROVIDER=custom
#   AI_BASE_URL=https://your-custom-endpoint/v1
#   AI_MODEL=your-model-name
#   AI_API_KEY=your-api-key

# Log level: debug | info | warn | error
LOG_LEVEL=info
